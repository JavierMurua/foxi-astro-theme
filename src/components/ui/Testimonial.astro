---
// - UI
import { Icon } from 'astro-icon/components'

// Props
type Props = {
	size?: string
	mobileSize?: string
	align?: 'left' | 'center'
	quoteSize?: number
	classes?: string
}
const {
	size = 'base',
	mobileSize = size,
	align = 'left',
	classes,
	quoteSize = 64
} = Astro.props
---

<div
	class:list={[
		'testimonial',
		{ ['testimonial--' + `${align}`]: align },
		{ ['text-' + `${mobileSize}`]: mobileSize },
		{ ['lg:text-' + `${size}`]: size },
		{ [`${classes}`]: classes }
	]}
>
	<div class="testimonial__container">
		<figure class="testimonial__figure">
			<blockquote class="testimonial__blockquote">
				<p>
					<!-- Componente legacy - Elfsight widget reemplazado por implementación nativa en BasicDark.astro -->
				<script is:inline src="https://static.elfsight.com/platform/platform.js" async></script>
				<div class="elfsight-app-40bb296f-4b1d-40fd-be7f-8a71a16af0ca" data-elfsight-app-lazy></div>
				</p>
			</blockquote>
		</figure>
		<Icon
			name="quotes"
			class="testimonial--quote"
			size={quoteSize}
			width={quoteSize}
			height={quoteSize}
		/>
	</div>
</div>

<style>
	.testimonial {
		@apply overflow-hidden leading-relaxed;
	}
	.testimonial--center {
		@apply text-center [&_.testimonial\_\_figcaption:has(.avatar)_.testimonial\_\_figcaption-cite-container]:text-left [&_.testimonial\_\_figcaption]:justify-center;
	}
	.testimonial--quote {
		@apply absolute left-6 top-6 z-0 text-neutral-50 dark:text-neutral-900/15;
	}
	.testimonial__container {
		@apply relative p-6;
	}
	.testimonial__figure {
		@apply relative z-10;
	}
	.testimonial__blockquote {
		@apply p-6 [&>p]:text-neutral-500 dark:[&>p]:text-neutral-800;
	}
	.testimonial__figcaption {
		@apply flex flex-col items-center gap-4 p-6 pt-2 text-sm leading-normal text-neutral-700 dark:text-neutral-700;
	}
	.testimonial__figcaption-container {
		@apply flex items-center gap-4 pt-4 text-sm;
	}
	.testimonial__figcaption-cite-container {
		@apply flex flex-col gap-1;
	}
	.testimonial__figcaption--credit {
		@apply font-bold uppercase;
	}
	.testimonial__figcaption--cite {
		@apply not-italic;
	}
</style>
