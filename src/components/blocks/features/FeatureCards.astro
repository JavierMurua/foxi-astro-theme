---
// ACTIVE COMPONENT - Used in index.astro
// Components
import Section from '../../ui/Section.astro'
import { Image } from 'astro:assets'

// Content
import feature01 from '../../../assets/cards/feature-01.webp'
import feature02 from '../../../assets/cards/feature-02.webp'
import feature03 from '../../../assets/cards/feature-03.webp'

const services = [
	{
		title: "Psicoterapia para adultos y jóvenes +18",
		subtitle: "Te ayudo a manejar el estrés, la ansiedad y las dificultades emocionales, generando un espacio de confianza y autoconocimiento para el logro de tus objetivos terapéuticos.",
		image: feature01,
	},
	{
		title: "Apto Psicológico",
		subtitle: "Evaluaciones psicológicas de aptitud para licencia de conducir particular y profesional, ingresos universitarios y empleos de alta responsabilidad.",
		image: feature02,
	},
	{
		title: "Evaluaciones psicotécnicas para empresas y particulares",
		subtitle: "Evaluaciones psicológicas en relación con puestos de trabajo, con el fin de permitir al empleador tomar decisiones o aplicar estrategias de acción en torno al postulante.",
		image: feature03,
	}
];
---

<Section id="features">
	<div class="header-container text-center max-w-4xl mx-auto mb-16">
		<h2 class="text-pretty text-4xl lg:text-5xl font-bold mb-6">
			Conocé <strong>mis servicios</strong> profesionales 
		</h2>
		<p class="text-lg text-neutral-400 leading-relaxed">
			Ofrezco un acompañamiento profesional adaptado a tus necesidades. Psicoterapia individual para adultos y jóvenes, aptos psicológicos y evaluaciones psicotécnicas con respaldo profesional. Atención online y presencial.
		</p>
	</div>

	<div class="services-grid grid gap-8 md:grid-cols-2 lg:grid-cols-3">
		{
			services.map((service) => (
				<article class="service-card group flex flex-col overflow-hidden rounded-2xl border border-white/10 bg-white/5 transition-all duration-300 hover:-translate-y-1 hover:border-white/20 hover:bg-white/[0.07] hover:shadow-2xl hover:shadow-pink-900/5">
					<div class="image-container relative aspect-[4/3] bg-white/[0.03] p-8 flex items-center justify-center overflow-hidden">
						<Image 
							src={service.image} 
							alt={service.title} 
							class="h-full w-full object-contain transition-transform duration-500 group-hover:scale-105" 
						/>
					</div>
					<div class="content-container flex flex-1 flex-col p-8">
						<h3 class="mb-4 text-xl font-bold text-white leading-snug">
							{service.title}
						</h3>
						<p class="text-neutral-400 text-sm leading-relaxed">
							{service.subtitle}
						</p>
					</div>
				</article>
			))
		}
	</div>
</Section>

<style>
	.service-card {
		/* Glassmorphism subtle effect */
		backdrop-filter: blur(8px);
	}

	/* Customizing strong tag within the title for consistency */
	h2 strong {
		@apply text-primary-500 font-bold;
	}
</style>
